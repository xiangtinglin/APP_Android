<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".MicrophoneTestActivity">

    <!-- 頂部 Banner -->
    <ImageView
        android:id="@+id/bannerTop"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:layout_gravity="top"
        android:contentDescription="@string/banner_desc"
        android:scaleType="centerCrop"
        android:src="@drawable/banner" />

    <!-- 工具列，包含返回鍵 -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:navigationIcon="?attr/homeAsUpIndicator" />

    <!-- 中間內容佈局 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 麥克風測試主要內容 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="130dp"
            android:layout_marginBottom="70dp"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 音量顯示 -->
            <TextView
                android:id="@+id/textVolume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Microphone Volume"
                android:textSize="18sp" />

            <!-- 心電圖顯示 -->
            <com.example.android_os_finalreport.EKGView
                android:id="@+id/ekgView"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="#000000" />

            <!-- 測試按鈕 -->
            <Button
                android:id="@+id/buttonSoundTest"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:text="Start Test" />

        </LinearLayout>

        <!-- 底部 FloatingActionButton -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="@dimen/fab_margin"
            android:layout_marginBottom="16dp"
            app:srcCompat="@android:drawable/ic_dialog_email" />

        <!-- 底部 Banner -->
        <ImageView
            android:id="@+id/bannerBottom"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_gravity="bottom"
            android:contentDescription="@string/banner_down_desc"
            android:scaleType="centerCrop"
            android:src="@drawable/banner_down" />

        <!-- 底部的 Home 按鈕 -->
        <ImageView
            android:id="@+id/home_button"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="12dp"
            android:contentDescription="Home"
            android:src="@drawable/icon_home" />

        <!-- 底部的 Refresh 按鈕 -->
        <ImageView
            android:id="@+id/refresh_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="36dp"
            android:layout_marginBottom="12dp"
            android:contentDescription="Refresh"
            android:src="@drawable/icon_refresh" />

        <!-- 底部的 Search 按鈕 -->
        <ImageView
            android:id="@+id/search_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="36dp"
            android:layout_marginBottom="12dp"
            android:contentDescription="Search"
            android:src="@drawable/icon_search" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
