<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 定義啟動畫面主題 -->
    <style name="Theme.MyApp.Splash" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- 隱藏標題欄 -->
        <item name="android:windowNoTitle">true</item>
        <!-- 設置狀態欄顏色為透明 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>


    <!-- 自定義按鈕樣式 -->
    <style name="RoundButtonSize" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">98dp</item>
        <item name="android:layout_height">98dp</item>
    </style>

</resources>


